{
  "name": "@mcpab/mui-theme",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "sideEffects": [
    "./dist/mui-augment.*"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./mui-augment": {
      "types": "./dist/mui-augment.d.ts",
      "import": "./dist/mui-augment.mjs",
      "require": "./dist/mui-augment.js"
    }
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "prepack": "pnpm build",
    "prepare": "pnpm build",
    "dev": "tsup --watch",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "@emotion/react": ">=11",
    "@emotion/styled": ">=11",
    "@mui/material": ">=6",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "files": [
    "dist"
  ]
}
